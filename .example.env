# ========== 必填：LLM / 代理 ==========
# LiteLLM Proxy 地址（容器内访问用服务名）
LLM_BASE_URL=http://litellm-proxy:4000
# 默认模型（可改 gemini-3 / gpt-4o 等）
LLM_MODEL=gpt-4o
# 访问 LiteLLM Proxy 的鉴权 key（litellm_settings.master_key）
LLM_API_KEY=changeme-proxy-key
# 备用：直连 OpenAI/Gemini 时使用（LiteLLM 配置也会用到）
OPENAI_API_KEY=sk-xxx
GEMINI_API_KEY=AIza-xxx
VERTEXAI_PROJECT=
VERTEXAI_LOCATION=global
VERTEX_MODEL=gemini-3.1-pro-preview
# Vertex 费用看板必填（按 1M token 的 USD 单价）
VERTEX_INPUT_PRICE_PER_1M_USD=
VERTEX_OUTPUT_PRICE_PER_1M_USD=
# 直连 Vertex（新命名，优先级高于 VERTEXAI_*）
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
VERTEX_CHAT_MODEL=gemini-3.1-pro-preview
# 如果当前 SDK 对目标模型暂不支持，会自动回退到 VERTEX_FALLBACK_MODEL。
VERTEX_FALLBACK_MODEL=gemini-2.5-pro
# 如需强制指定最终模型（覆盖所有自动逻辑），可设置：
VERTEX_FORCE_MODEL=
# 直连 Vertex 时服务账号文件在容器内路径
GOOGLE_APPLICATION_CREDENTIALS=/app/vertex-sa.json
# 用于加密保存 BBDown 登录凭据（建议设置为 32+ 位随机字符串并长期固定）
CREDENTIAL_ENCRYPTION_KEY=

# ========== 必填：字幕抓取 ==========
# BBDown 可执行文件路径
BBDOWN_BIN=BBDown
# 兼容旧逻辑：不建议使用。优先在 Settings 页手动填写 SESSDATA 或完整 Cookie。
BILIBILI_SESSION_TOKEN=
# 登录 savesubs.com 后在请求头里找到 X-Auth-Token
SAVESUBS_X_AUTH_TOKEN=

# ========== 必填：Redis（替换 Upstash，指向自有 Redis）==========
REDIS_URL=redis://taleweave-redis:6379/0
REDIS_TLS=false
REDIS_PASSWORD=

# ========== 可选：监控/付费/埋点/站点信息（不需要可留空） ==========
SENTRY_AUTH_TOKEN=
LEMON_API_KEY=
NEXT_PUBLIC_SEGMENT_WRITEKEY=
NEXT_PUBLIC_SITE_URL=
INTERNAL_API_HOSTNAME=

# ========== 临时占位：Supabase（避免旧代码报错，实际未使用） ==========
NEXT_PUBLIC_SUPABASE_URL=http://dummy.supabase.local
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-anon-key
